# db
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# client
NEXT_PUBLIC_GRAPHQL_ENDPOINT=your_graphql_endpoint # the one that is used in this app: http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS_ENDPOINT= your_graphql_ws_endpoint # the one that is used in this app: ws://localhost:4000/graphql

# server
DATABASE_URL="your_database_url"
JWT_SECRET="your_jwt_secret"
